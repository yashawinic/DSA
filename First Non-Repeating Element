import java.util.*;
class Main {
    public static void main(String[] args) {
        int[] arr={1,7,3,4,1,2};
        HashMap<Integer,Integer> map=new HashMap<>();
        for(int num:arr){
            map.put(num,map.getOrDefault(num,0)+1);
            
        }
        for(int n:arr){
            if(map.get(n)==1){
                System.out.print(n);
                return;
            }
        }
    }
}
