import java.util.*;
class Main {
    public static void main(String[] args) {
        int[] arr={1,7,3,4,1,2};
        int t=9;
        HashMap<Integer,Integer> map=new HashMap<>();
        for(int i=0;i<arr.length;i++){
            int c=t-arr[i];
            if(map.containsKey(c)){
                System.out.print(map.get(c)+" "+i);
                return;
            }
            map.put(arr[i],i);
            
        }
    }
}
